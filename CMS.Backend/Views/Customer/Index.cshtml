@model IEnumerable<CMS.Data.Entities.Customer>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách khách hàng";
}

<h2>Danh sách khách hàng</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Thêm khách hàng
    </a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Điện thoại</th>
            <th>Địa chỉ</th>
            <th width="250"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>@item.Address</td>
                <td>
                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info">
                        Chi tiết
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning">
                        Sửa
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       onclick="return confirm('Bạn có chắc muốn xóa?')"
                       class="btn btn-danger">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>