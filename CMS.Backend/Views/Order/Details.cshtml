@model List<CMS.Data.Entities.OrderDetail>

@{
    Layout = "_LayoutAdmin";

    var order = ViewBag.Order as CMS.Data.Entities.Order;
    decimal total = Model != null ? Model.Sum(x => x.UnitPrice * x.Quantity) : 0;
}

<div class="container mt-4">

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="/Order">Danh sách đơn hàng</a>
            </li>
            <li class="breadcrumb-item active">
                Chi tiết đơn hàng
            </li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Thông tin đơn hàng</h4>
        </div>

        <div class="card-body">
            @if (order != null)
            {
                <div class="row">
                    <div class="col-md-6">
                        <p>
                            <strong>Mã đơn hàng:</strong>
                            #@order.Id
                        </p>

                        <p>
                            <strong>Ngày đặt:</strong>
                            @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                        </p>

                        <p>
                            <strong>Trạng thái:</strong>
                            @order.Status
                        </p>
                    </div>

                    <div class="col-md-6">
                        <p>
                            <strong>Khách hàng:</strong>
                            @(order.Customer != null ? order.Customer.FullName : "Không có thông tin")
                        </p>

                        <p>
                            <strong>Ghi chú:</strong>
                            @(string.IsNullOrEmpty(order.Notes) ? "Không có ghi chú" : order.Notes)
                        </p>

                        <p>
                            <strong>Tổng tiền:</strong>
                            <span class="text-danger fw-bold">
                                @total.ToString("N0") VNĐ
                            </span>
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Sản phẩm trong đơn hàng</h5>
        </div>

        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 60px;">STT</th>
                                <th>Tên sản phẩm</th>
                                <th style="width: 120px;">Số lượng</th>
                                <th style="width: 180px;">Đơn giá</th>
                                <th style="width: 180px;">Thành tiền</th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int stt = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@stt</td>

                                    <td>
                                        @(item.Product != null ? item.Product.Name : "Sản phẩm không tồn tại")
                                    </td>

                                    <td>
                                        @item.Quantity
                                    </td>

                                    <td>
                                        @item.UnitPrice.ToString("N0") VNĐ
                                    </td>

                                    <td class="fw-bold text-danger">
                                        @((item.UnitPrice * item.Quantity).ToString("N0")) VNĐ
                                    </td>
                                </tr>

                                stt++;
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-bold">
                                    Tổng cộng:
                                </td>
                                <td class="fw-bold text-danger">
                                    @total.ToString("N0") VNĐ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Đơn hàng này chưa có sản phẩm nào.
                </div>
            }
        </div>
    </div>

    <div class="mt-4">
        <a href="/Order" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Quay lại danh sách
        </a>

        @if (order != null)
        {
            <a href="/Order/Edit/@order.Id" class="btn btn-warning">
                Cập nhật trạng thái
            </a>
        }
    </div>

</div>