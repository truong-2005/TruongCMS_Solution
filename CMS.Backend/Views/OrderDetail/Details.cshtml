@model CMS.Data.Entities.OrderDetail

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="/OrderDetails">Danh sách chi tiết đơn hàng</a>
            </li>
            <li class="breadcrumb-item active">Chi tiết đơn hàng</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Chi tiết đơn hàng #@Model.Id</h4>
                </div>

                <div class="card-body">
                    <table class="table table-bordered">
                        <tbody>
                            <tr>
                                <th style="width: 30%;">Mã chi tiết</th>
                                <td>@Model.Id</td>
                            </tr>

                            <tr>
                                <th>Mã đơn hàng</th>
                                <td>@Model.OrderId</td>
                            </tr>

                            <tr>
                                <th>Mã sản phẩm</th>
                                <td>@Model.ProductId</td>
                            </tr>

                            <tr>
                                <th>Số lượng</th>
                                <td>@Model.Quantity</td>
                            </tr>

                            <tr>
                                <th>Đơn giá</th>
                                <td>@Model.UnitPrice.ToString("N0") VNĐ</td>
                            </tr>

                            <tr>
                                <th>Thành tiền</th>
                                <td class="fw-bold text-danger">
                                    @((Model.Quantity * Model.UnitPrice).ToString("N0")) VNĐ
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="mt-4 border-top pt-3">
                        <a href="/OrderDetails" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại danh sách
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>