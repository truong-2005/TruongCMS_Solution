@model IEnumerable<CMS.Data.Entities.User>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">QUẢN LÝ THÀNH VIÊN</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm thành viên mới
        </a>
    </div>

    <table class="table table-hover shadow-sm border">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên đăng nhập</th>
                <th>Họ và Tên</th>
                <th>Quyền hạn</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td><strong>@user.Username</strong></td>
                    <td>@user.FullName</td>
                    <td>
                        @if (user.Role == "Admin")
                        {
                            <span class="badge bg-danger">@user.Role</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">@user.Role</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@user.Id"
                           class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên @user.Username không?')">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>